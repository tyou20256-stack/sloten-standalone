{
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "es2022": true,
    "node": true,
    "worker": true
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "no-undef": "error",
    "no-constant-condition": ["warn", { "checkLoops": false }],
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-async-promise-executor": "error",
    "no-fallthrough": "error",
    "no-var": "warn",
    "prefer-const": ["warn", { "destructuring": "all" }],
    "eqeqeq": ["warn", "smart"],
    "no-implicit-globals": "error",
    "no-throw-literal": "error",
    "no-return-await": "off",
    "require-atomic-updates": "off"
  },
  "globals": {
    "crypto": "readonly",
    "fetch": "readonly",
    "Headers": "readonly",
    "Request": "readonly",
    "Response": "readonly",
    "URL": "readonly",
    "URLSearchParams": "readonly",
    "TextEncoder": "readonly",
    "TextDecoder": "readonly",
    "AbortController": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    ".wrangler/",
    "public/admin/vendor/",
    "public/widget/widget.js",
    "**/*.min.js"
  ]
}
